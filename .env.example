NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Server RPC (not sent to the browser)
ALCHEMY_API_KEY=
# Browser RPC (bundled into client JS — use a separate Alchemy key with origin allowlist when possible)
NEXT_PUBLIC_ALCHEMY_API_KEY=
# COINBASE_CDP_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — Safe Transaction Service sync (https://developer.safe.global)
# Free tier: 5 req/s, 50K req/month. Curator throttles client calls; sync is manual only.
# NEXT_PUBLIC_SAFE_API_KEY=

# MORPHO_API_URL=
